{
  "name": "smartq-bot",
  "version": "1.0.0",
  "description": "Telegram bot for ordering drinks from SmartQ office cafes",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc && npm run copy-assets",
    "copy-assets": "mkdir -p dist/config dist/data && cp src/config/*.json dist/config/ && cp src/data/*.json dist/data/ 2>/dev/null || true",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "telegram",
    "bot",
    "smartq",
    "coffee"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "grammy": "^1.35.0",
    "puppeteer-core": "^24.37.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
